# Copy to .env and fill in what you need. Everything here is optional —
# the app degrades gracefully when a value is absent.
#
# WARNING: keep values as simple KEY=value lines — no spaces, quotes,
# commas, or `#` in values. This file is parsed by both make (-include .env)
# and dotenv tooling, and neither handles quoting the same way.

# Enables AI-assisted PDF parsing (backend pdf_service).
GEMINI_API_KEY=

# Vertex AI fallback for the backend, used only when GEMINI_API_KEY is
# empty. gcloud is not installed in the backend image, so the project
# cannot be auto-detected there — set it here and it is forwarded into the
# container. Without it, Vertex calls hit the "my-project" placeholder and
# 403. Credentials come from ADC (staged automatically by `make up`); the
# aiplatform.googleapis.com API must be enabled on the project. GCP_LOCATION
# defaults to us-central1 when unset.
GCP_PROJECT=
GCP_LOCATION=

# Optional override: host path to a Google Application Default Credentials
# JSON file. Normally leave this unset — `make up` auto-discovers the
# gcloud default (~/.config/gcloud/application_default_credentials.json,
# honoring CLOUDSDK_CONFIG) and stages a container-readable copy under
# .container-secrets/. Set this only if your ADC lives elsewhere.
GOOGLE_ADC_FILE=

# Optional override: base URL of a local Ollama daemon for the AI PDF
# Extractor's "Use local LLM" option. Leave unset for the defaults: native
# dev uses http://localhost:11434; `make up` forwards a host-reachable
# default into the backend container (http://host.docker.internal:11434 on
# Docker, http://192.168.64.1:11434 on Apple Container). For containers to
# reach it, the HOST daemon must listen on a non-loopback interface — run
# it with OLLAMA_HOST=0.0.0.0 (see README).
OLLAMA_HOST=

# Backend URL override for native (non-container) dev. Default is
# http://127.0.0.1:8000; in containers it's set automatically.
# BACKEND_URL=http://127.0.0.1:8000
